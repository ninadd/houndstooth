# Copy this file to `.env.local` and fill in your own values.
# Tip: set DATA_PROVIDER=mock below to run the app with NO external
# credentials at all (mock data, no SnapTrade/Gemini keys needed).

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key
# Server-only. Bypasses RLS. Never expose to the browser.

SUPABASE_SERVICE_ROLE_KEY=


# --- SnapTrade ---
# Partner keys from the SnapTrade Dashboard → API Keys. Server-only; the SDK
# signs each request (and webhook verification reuses the consumer key).

SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=

# Personal-tier keys auto-provision ONE user at signup (no registerUser). Its
# fixed userId + userSecret are in the Dashboard → Settings → Security.

SNAPTRADE_USER_ID=
SNAPTRADE_USER_SECRET=

# Data provider selector: "snaptrade" (default) or "mock" (offline, no creds).

DATA_PROVIDER=snaptrade

# --- Gemini (Milestone 5) ---

GEMINI_API_KEY=

# --- Cron (Milestone 5) ---
# Shared secret to authorize the Vercel Cron request to /api/cron/daily.
CRON_SECRET=

# --- MFA device-trust ---
# HMAC key that signs the "trust this device" cookie. Without it, device-trust
# fails closed (MFA is always required). Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
MFA_TRUST_SECRET=
